    "@types/opossum": "^8.1.7",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.0.0",
    "nock": "^13.5.4",
    "nodemon": "^3.1.4",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
