# ── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── MongoDB ──────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/immuniwatch

# ── JWT ──────────────────────────────────────────────────
JWT_SECRET=change_me_min_64_chars_random_string_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Cloudinary ───────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=immuniwatch-ng
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── ML Service ───────────────────────────────────────────
ML_SERVICE_URL=http://localhost:8000
ML_API_KEY=change_me_min_32_chars
ML_TIMEOUT_MS=5000
ML_BATCH_TIMEOUT_MS=30000
ML_PSI_THRESHOLD=0.20
ML_MIN_FEEDBACK_SAMPLES=500
ML_MOCK_MODE=true

# ── Circuit Breaker ──────────────────────────────────────
CB_ERROR_THRESHOLD=50
CB_RESET_TIMEOUT_MS=30000
CB_VOLUME_THRESHOLD=5

# ── Kafka ────────────────────────────────────────────────
KAFKA_ENABLED=false
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=iw-backend
KAFKA_CLIENT_ID=iw-backend-server

# ── Classification Thresholds ────────────────────────────
HITL_THRESHOLD=0.75
HIGH_PRIORITY_THRESHOLD=0.85

# ── Alerts ───────────────────────────────────────────────
SURGE_THRESHOLD=200
ANALYST_OVERRIDE_RATE_ALERT=15
